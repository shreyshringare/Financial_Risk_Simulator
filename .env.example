# --- Groq (FREE — recommended) ---
# Sign up: https://console.groq.com → API Keys
# Model: llama-3.3-70b-versatile (14,400 req/day free)
GROQ_API_KEY=your-groq-api-key-here

# --- OpenAI (paid fallback — used if GROQ_API_KEY not set) ---
# OPENAI_API_KEY=your-openai-api-key-here

# --- Required for RAG embeddings (OpenAI embeddings only) ---
# If using Groq for chat but still need embeddings, OpenAI key still required.
# For free embeddings alternative, switch knowledge_base.py to HuggingFaceEmbeddings.
OPENAI_API_KEY=your-openai-api-key-here
