# --- Groq (FREE — recommended for chat) ---
# Sign up: https://console.groq.com → API Keys
# Model: llama-3.3-70b-versatile (14,400 req/day free, no credit card)
GROQ_API_KEY=your-groq-api-key-here

# --- OpenAI (paid fallback — only needed if GROQ_API_KEY not set) ---
# OPENAI_API_KEY=your-openai-api-key-here

# NOTE: RAG embeddings use BAAI/bge-base-en-v1.5 via HuggingFace (fully local).
# No OpenAI key needed for embeddings. Model downloads once (~110MB) on first run.
